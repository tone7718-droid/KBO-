{
  "name": "kbo-booking-clock",
  "version": "1.0.0",
  "private": true,
  "description": "Samsung Lions Ticketlink booking countdown helper",
  "scripts": {
    "scrape": "node scripts/scraper.js",
    "scrape:local": "cross-env SCRAPER_MODE=local SCRAPER_HEADLESS=false node scripts/scraper.js",
    "scrape:headful": "cross-env SCRAPER_MODE=local SCRAPER_HEADLESS=false SCRAPER_DEBUG=1 node scripts/scraper.js",
    "scrape:ci": "cross-env SCRAPER_MODE=ci SCRAPER_HEADLESS=true node scripts/scraper.js",
    "scrape:debug": "cross-env SCRAPER_DEBUG=1 node scripts/scraper.js",
    "serve": "npx --yes serve@latest -l 5173 ."
  },
  "dependencies": {
    "puppeteer": "^24.22.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
